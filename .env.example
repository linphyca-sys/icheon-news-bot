# 필수
BOT_NAME=이천 뉴스봇

# BotFather(@BotFather)에서 봇 생성 후 받은 토큰
TELEGRAM_BOT_TOKEN=

# 뉴스를 받을 채널 chat_id (get_chat_id.py로 확인, -100으로 시작하는 음수)
TELEGRAM_CHAT_ID=

# 검색 키워드는 keywords.txt에서 관리합니다. 여기에 쓰면 이 값이 우선합니다.
KEYWORDS=

# 선택
INTERVAL_MINUTES=10
MAX_PER_KEYWORD=0
FIRST_RUN_SEND=0
MAX_AGE_HOURS=36
NAVER_MAX_START=1000

# 네이버 뉴스 검색 API 키 (필수)
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 사용 API "검색" 선택
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
